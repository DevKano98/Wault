# -- LOCAL POSTGRES / NEO4J DESKTOP --
DATABASE_URL=postgresql://wault_user:wault_pass@localhost:5432/wault_db
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=wault_neo4j_pass

# -- CLOUD: UPSTASH REDIS --
UPSTASH_REDIS_REST_URL=https://YOUR_ENDPOINT.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_TOKEN
UPSTASH_REDIS_HOST=YOUR_TCP_HOST.upstash.io

# -- CLOUD: BACKBLAZE B2 --
B2_ACCOUNT_ID=YOUR_ACCOUNT_ID
B2_APPLICATION_KEY=YOUR_APP_KEY
B2_BUCKET_NAME=wault-files
B2_BUCKET_ID=YOUR_BUCKET_ID
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com

# -- CLOUD: RESEND EMAIL --
RESEND_API_KEY=re_YOUR_KEY
FROM_EMAIL=WAULT <no-reply@wault.app>

# -- CLOUD: POLYGON BLOCKCHAIN --
POLYGON_RPC_URL=https://polygon-mumbai.g.alchemy.com/v2/YOUR_KEY
PRIVATE_KEY=0xYOUR_WALLET_PRIVATE_KEY
CONTRACT_ADDRESS=0xTO_BE_FILLED_AFTER_DEPLOY
POLYGONSCAN_API_KEY=YOUR_POLYGONSCAN_API_KEY

# -- SERVER --
PORT=3001
NODE_ENV=development
BACKEND_URL=http://localhost:3001
JWT_SECRET=replace_with_64_char_random_string
JWT_EXPIRES_IN=7d

# -- SERVICES --
ML_SERVICE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:3001/api

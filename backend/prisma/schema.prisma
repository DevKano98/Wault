// Setup commands:
// npx prisma migrate dev --name init
// npx prisma generate
// npx prisma studio

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum VaultItemType {
  PASSWORD
  NOTE
  DOCUMENT
}

enum AccessStatus {
  PENDING
  ACTIVE
  REVOKED
}

enum TriggerStatus {
  WARNING_SENT
  TRIGGERED
  CANCELLED
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  passwordHash   String
  name           String
  lastActiveAt   DateTime        @default(now())
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  vaultItems     VaultItem[]
  beneficiaries  Beneficiary[]
  activityLogs   ActivityLog[]
  inactivityRule InactivityRule?
  triggerEvents  TriggerEvent[]
}

model VaultItem {
  id            String        @id @default(uuid())
  userId        String
  type          VaultItemType
  title         String
  encryptedData String
  iv            String
  fileUrl       String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessGrants  AccessGrant[]

  @@index([userId])
}

model Beneficiary {
  id                String        @id @default(uuid())
  userId            String
  email             String
  name              String
  verificationToken String?       @unique
  isVerified        Boolean       @default(false)
  createdAt         DateTime      @default(now())
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessGrants      AccessGrant[]

  @@unique([userId, email])
  @@index([userId])
}

model AccessGrant {
  id            String       @id @default(uuid())
  vaultItemId   String
  beneficiaryId String
  status        AccessStatus
  grantedAt     DateTime?
  createdAt     DateTime     @default(now())
  vaultItem     VaultItem    @relation(fields: [vaultItemId], references: [id], onDelete: Cascade)
  beneficiary   Beneficiary  @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)

  @@index([vaultItemId])
  @@index([beneficiaryId])
}

model InactivityRule {
  id            String   @id @default(uuid())
  userId        String   @unique
  thresholdDays Int      @default(30)
  warningDays   Int      @default(7)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  ipAddress String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TriggerEvent {
  id          String        @id @default(uuid())
  userId      String
  status      TriggerStatus
  triggeredAt DateTime?
  createdAt   DateTime      @default(now())
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model BlockchainLog {
  id        String   @id @default(uuid())
  txHash    String   @unique
  eventType String
  data      Json
  createdAt DateTime @default(now())
}
